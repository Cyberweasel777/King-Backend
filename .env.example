# King Backend Environment Variables

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_ANON_KEY=your-anon-key

# Redis (for BullMQ queues)
REDIS_URL=redis://localhost:6379

# Admin IDs (comma-separated Telegram IDs)
PAYMENT_ADMIN_IDS=8063432083

# API Base URL (for checkout links)
API_BASE_URL=https://king-backend.fly.dev

# ============================================
# TELEGRAM BOT TOKENS (Get from @BotFather)
# ============================================

BOTINDEX_BOT_TOKEN=your-bot-token-here
MEMERADAR_BOT_TOKEN=your-bot-token-here
ARBWATCH_BOT_TOKEN=your-bot-token-here

# ============================================
# STRIPE CONFIGURATION (Per App)
# Create accounts at https://stripe.com
# ============================================

# --- BotIndex ---
BOTINDEX_STRIPE_SECRET_KEY=sk_test_...
BOTINDEX_STRIPE_WEBHOOK_SECRET=whsec_...
BOTINDEX_STRIPE_PRICE_BASIC=price_...
BOTINDEX_STRIPE_PRICE_PRO=price_...

# --- MemeRadar ---
MEMERADAR_STRIPE_SECRET_KEY=sk_test_...
MEMERADAR_STRIPE_WEBHOOK_SECRET=whsec_...
MEMERADAR_STRIPE_PRICE_BASIC=price_...
MEMERADAR_STRIPE_PRICE_PRO=price_...

# --- ArbWatch ---
ARBWATCH_STRIPE_SECRET_KEY=sk_test_...
ARBWATCH_STRIPE_WEBHOOK_SECRET=whsec_...
ARBWATCH_STRIPE_PRICE_BASIC=price_...
ARBWATCH_STRIPE_PRICE_PRO=price_...

# ============================================
# SHELL ROLLOUT FLAGS (Landing + Dashboard)
# ============================================

# Staged rollout phase for shell endpoints
# Valid: P1, P2, P3, P4, P5
SHELL_ROLLOUT_PHASE=P1

# Optional CSV overrides, e.g.:
# signalSummary=true,opportunityTimeline=true,entitlementStatus=true,pricingMetadata=true,dashboardStatusBlock=true
SHELL_FEATURE_OVERRIDES=

# ============================================
# OPTIONAL: Meta CAPI (Facebook Conversions API)
# ============================================

# BOTINDEX_META_CAPI_ACCESS_TOKEN=
# MEMERADAR_META_CAPI_ACCESS_TOKEN=
# ARBWATCH_META_CAPI_ACCESS_TOKEN=
