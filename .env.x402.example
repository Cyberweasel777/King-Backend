# x402 runtime toggle:
# 1 = enforce x402 payment gates on protected endpoints
# 0 = bypass x402 gates (all endpoints should return normal data)
X402_ENABLED=1

# Base wallet address that receives x402 payments (EVM format).
# Use your Base wallet for the selected network below.
X402_WALLET_ADDRESS=0xYOUR_BASE_WALLET_ADDRESS

# x402 settlement network:
# - base-sepolia for testnet/local development
# - base for production mainnet
X402_NETWORK=base-sepolia

# x402 facilitator endpoint:
# - Testnet/default: official x402 test facilitator
# - Mainnet: Coinbase CDP x402 facilitator
X402_FACILITATOR_URL=https://www.x402.org/facilitator

# Mainnet cutover (3 changes):
# 1) Set X402_NETWORK=base
# 2) Set X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# 3) Set X402_WALLET_ADDRESS to your production Base mainnet wallet
