{
  "name": "@metaplex-foundation/genesis",
  "version": "0.23.0",
  "description": "The Metaplex Genesis Program",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "build:docs": "typedoc",
    "test": "ava --timeout=10m test/testsV2",
    "test:one": "ava --timeout=10m",
    "test:all": "ava --timeout=10m test/testsV1 test/testsV2 test/feeTests test/penaltyTests",
    "bench": "rm -f output.json && ava ./dist/bench/*.js --serial --no-worker-threads --timeout=10000",
    "lint": "eslint --ext js,ts,tsx src",
    "lint:fix": "eslint --fix --ext js,ts,tsx src",
    "format": "prettier --check src test --ignore-path .prettierignore",
    "format:fix": "prettier --write src test --ignore-path .prettierignore"
  },
  "files": [
    "/dist/src"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "homepage": "https://metaplex.com",
  "repository": "https://github.com/metaplex-foundation/genesis.git",
  "author": "Metaplex Maintainers <contact@metaplex.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
    "@metaplex-foundation/mpl-toolbox": "^0.10.0",
    "@noble/hashes": "^1.7.1"
  },
  "peerDependencies": {
    "@metaplex-foundation/umi": "^1.4.1"
  },
  "devDependencies": {
    "@ava/typescript": "^5.0.0",
    "@metaplex-foundation/mpl-distro": "^0.4.0",
    "@metaplex-foundation/umi": "^1.4.1",
    "@metaplex-foundation/umi-bundle-tests": "^1.4.1",
    "@solana/web3.js": "^1.73.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.46.1",
    "ava": "^6.1.3",
    "eslint": "^8.0.1",
    "eslint-config-airbnb-typescript": "^17.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.2.1",
    "p-map": "4",
    "prettier": "^3.2.5",
    "rimraf": "^3.0.2",
    "typedoc": "^0.23.16",
    "typedoc-plugin-expand-object-like-types": "^0.1.1",
    "typedoc-plugin-missing-exports": "^1.0.0",
    "typescript": "^4.9.4",
    "vercel": "40.1.0"
  },
  "ava": {
    "typescript": {
      "compile": false,
      "rewritePaths": {
        "src/": "dist/src/",
        "test/": "dist/test/",
        "bench/": "dist/bench/"
      }
    }
  },
  "packageManager": "pnpm@8.2.0"
}
