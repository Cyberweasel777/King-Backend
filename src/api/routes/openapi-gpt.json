    "/api/botindex/crypto/intel": {
      "get": {
        "operationId": "getCryptoIntel",
        "summary": "DeepSeek-powered deep analysis of crypto market trends",
        "tags": ["Intel"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Token symbol to analyze (e.g. BTC, ETH)"
          }
        ],
        "responses": { "200": { "description": "Crypto intel analysis" } }
