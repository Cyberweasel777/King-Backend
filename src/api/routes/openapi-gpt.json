{
  "openapi": "3.1.0",
  "info": {
    "title": "BotIndex API",
    "version": "1.0.0",
    "description": "Real-time DeFi analytics, whale tracking, funding arbitrage, and market intelligence for AI agents."
  },
  "servers": [
    { "url": "https://king-backend.fly.dev" }
  ],
  "paths": {
    "/api/botindex/hyperliquid/funding-arb": {
      "get": {
        "operationId": "getFundingArb",
        "summary": "Get Hyperliquid vs Binance funding rate arbitrage opportunities",
        "tags": ["Hyperliquid"],
        "responses": { "200": { "description": "Funding arb opportunities" } }
      }
    },
