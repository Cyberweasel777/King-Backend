    "/api/botindex/keys/register": {
      "get": {
        "operationId": "registerApiKey",
        "summary": "Register a free BotIndex API key",
        "tags": ["Keys"],
        "parameters": [
          {
            "name": "plan",
            "in": "query",
            "schema": { "type": "string", "enum": ["free", "pro"] },
            "description": "Plan type (free or pro)"
          }
        ],
        "responses": { "200": { "description": "API key registration" } }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    { "ApiKeyAuth": [] }
  ]
}
