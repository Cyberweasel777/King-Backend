# KING Bot Launcher Environment Configuration
# Copy to .env and fill in your bot tokens

# ============================================
# TELEGRAM BOTS (11 total)
# ============================================

# SpreadHunter - Arbitrage opportunities
TELEGRAM_SPREADHUNTER_ENABLED=true
TELEGRAM_SPREADHUNTER_TOKEN=your_spreadhunter_token_here

# DeckVault - Research & due diligence
TELEGRAM_DECKVAULT_ENABLED=true
TELEGRAM_DECKVAULT_TOKEN=your_deckvault_token_here

# MemeRadar - Meme coin intelligence
TELEGRAM_MEMERADAR_ENABLED=true
TELEGRAM_MEMERADAR_TOKEN=your_memeradar_token_here

# BotIndex - Ecosystem directory
TELEGRAM_BOTINDEX_ENABLED=true
TELEGRAM_BOTINDEX_TOKEN=your_botindex_token_here

# AirdropHunter - Airdrop farming
TELEGRAM_AIRDROPHUNTER_ENABLED=true
TELEGRAM_AIRDROPHUNTER_TOKEN=your_airdrophunter_token_here

# SignalOracle - Trading signals
TELEGRAM_SIGNALORACLE_ENABLED=true
TELEGRAM_SIGNALORACLE_TOKEN=your_signloracle_token_here

# WhaleWatcher - Whale movements
TELEGRAM_WHALEWATCHER_ENABLED=true
TELEGRAM_WHALEWATCHER_TOKEN=your_whalewatcher_token_here

# NicheHunter - Niche discovery
TELEGRAM_NICHEHUNTER_ENABLED=true
TELEGRAM_NICHEHUNTER_TOKEN=your_nichehunter_token_here

# ChainPulse - Cross-chain data
TELEGRAM_CHAINPULSE_ENABLED=true
TELEGRAM_CHAINPULSE_TOKEN=your_chainpulse_token_here

# YieldHunter - Yield farming
TELEGRAM_YIELDHUNTER_ENABLED=true
TELEGRAM_YIELDHUNTER_TOKEN=your_yieldhunter_token_here

# ValidatorX - Validator analytics
TELEGRAM_VALIDATORX_ENABLED=true
TELEGRAM_VALIDATORX_TOKEN=your_validatorx_token_here

# ============================================
# DISCORD BOTS (4 total)
# ============================================

# AlphaCaller - Alpha calls
DISCORD_ALPHACALLER_ENABLED=true
DISCORD_ALPHACALLER_TOKEN=your_alphacaller_token_here

# DAOGrinder - DAO governance
DISCORD_DAOGRINDER_ENABLED=true
DISCORD_DAOGRINDER_TOKEN=your_daogrinder_token_here

# LaunchSniper - Launch alerts
DISCORD_LAUNCHSNIPER_ENABLED=true
DISCORD_LAUNCHSNIPER_TOKEN=your_launchsniper_token_here

# VaultGuard - Security monitoring
DISCORD_VAULTGUARD_ENABLED=true
DISCORD_VAULTGUARD_TOKEN=your_vaultguard_token_here
